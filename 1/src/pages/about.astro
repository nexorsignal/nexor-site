---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="About" path="/about/" description="About NEXOR SIGNAL.">
  <section class="container page-hero">
    <div class="eyebrow">About</div>
    <h1>NEXOR SIGNAL is an independent signal layer for AI, systems, markets, and compute culture.</h1>
    <p>Built for people who want less noise, cleaner signal, and clearer decisions.</p>
  </section>
  <section class="container section">
    <div class="split">
      <article class="card">
        <small>Position</small>
        <h3>Signal over noise.</h3>
        <p>NEXOR SIGNAL turns short video ideas, market observations, and systems notes into readable posts. The goal is not more content. The goal is better signal.</p>
      </article>
      <article class="card">
        <small>Coverage</small>
        <h3>AI, systems, compute, markets.</h3>
        <p>We cover the interface layer, infrastructure layer, culture layer, and capital layer behind the next wave of compute.</p>
      </article>
    </div>
  </section>
</BaseLayout>
