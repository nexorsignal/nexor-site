---
import { site } from '@/config/site';
---
<footer class="footer">
  <div class="container footer-grid">
    <div>
      <a class="brand" href="/" aria-label="NEXOR SIGNAL home">
        <span class="mark" aria-hidden="true"><i></i><i></i></span>
        <span>NEXOR SIGNAL</span>
      </a>
      <p>{site.tagline}</p>
      <p>AI, systems, markets, and compute culture. Clear thinking for people who build, buy, and decide.</p>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/signal/">Signal Notes</a>
      <a href="/essays/">Essays</a>
      <a href="/markets/">Markets</a>
      <a href="/archive/">Archive</a>
      <a href="/about/">About</a>
      <a href="/support/">Support</a>
    </nav>

    <div>
      <p>© 2026 NEXOR SIGNAL<br />All rights reserved.</p>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <div class="footer-legal" aria-label="Legal and feeds">
        <a href="/privacy/">Privacy</a>
        <span>·</span>
        <a href="/contact/">Contact</a>
        <span>·</span>
        <a href={site.social.rss}>RSS</a>
      </div>
    </div>
  </div>
</footer>
