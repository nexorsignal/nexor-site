---
import { site } from '@/config/site';
---
<section class="container section" id="newsletter">
  <div class="newsletter">
    <div>
      <div class="eyebrow">Stay in the signal</div>
      <h2>Get essays and insights straight to your inbox.</h2>
      <p>No spam. Just signal. Unsubscribe anytime.</p>
    </div>
    <form class="form newsletter-form" action={site.newsletter.action} method="post" target="_blank">
      <input type="hidden" name="tag" value="website" />
      <input class="input" type="email" name="email" placeholder="Enter your email" aria-label="Email address" required />
      <button class="btn solid" type="submit">Subscribe</button>
      <p class="form-note">
        By subscribing, you agree to receive occasional emails from NEXOR SIGNAL.
        You can unsubscribe anytime. Read the <a href="/privacy/">Privacy Policy</a>.
      </p>
    </form>
  </div>
</section>
