---
import { site } from '@/config/site';
---
<section class="container support-section">
  <div class="support-bar">
    <div class="support-copy">
      <div class="eyebrow">Reader supported</div>
      <h2>Independent signal. Reader supported.</h2>
      <p>If NEXOR SIGNAL helps you think clearer, support the work. No sponsored noise. No feed chasing. Just better essays, notes, and research.</p>
    </div>
    <div class="support-actions">
      <a class="btn solid" href={site.support.signal}>Support the Signal</a>
      <a class="btn" href={site.support.coffee} target="_blank" rel="noopener noreferrer">Buy Me a Coffee</a>
    </div>
  </div>
</section>
