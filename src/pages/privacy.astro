---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy" path="/privacy/" description="NEXOR SIGNAL privacy policy.">
  <section class="container article">
    <div class="eyebrow">Privacy</div>
    <h1>Privacy Policy</h1>
    <p class="desc">Simple version: no tracking stack is required for this site.</p>
    <p>NEXOR SIGNAL is built as a static website. By default, it does not require accounts, cookies, or invasive analytics.</p>
    <p>If you subscribe or contact us, you choose to share your email address so we can respond or send updates. Replace this policy with your final legal text before heavy public launch.</p>
    <p>External services such as email, payment, or newsletter tools may have their own policies.</p>
  </section>
</BaseLayout>
